  "examples": [
    {
      "name": "Point-buy Fighter",
      "input": {
        "name": "Thorin Stoneforge",
        "class": "fighter",
        "creation_method": "point_buy",
        "ability_input": {
          "STR": 15,
          "DEX": 12,
          "CON": 14,
          "INT": 10,
          "WIS": 12,
          "CHA": 8
        },
        "chosen_skills": [
          "athletics",
          "perception"
        ],
        "equipment_choice": "option_a",
        "race": "dwarf",
        "background": "soldier"
      },
      "execution": "generate_ability_scores(point_buy) -> assign_proficiencies(fighter) -> assign_equipment(fighter) -> create_character",
      "output": {
        "valid": true,
        "character": {
          "hp": 12,
          "ac": 16,
          "proficiency_bonus": 2
        },
        "errors": []
      }
    },
    {
      "name": "Standard-array Wizard",
      "input": {
        "name": "Elara Moonwhisper",
        "class": "wizard",
        "creation_method": "standard_array",
        "ability_input": {
          "STR": 8,
          "DEX": 14,
          "CON": 13,
          "INT": 15,
          "WIS": 12,
          "CHA": 10
        },
