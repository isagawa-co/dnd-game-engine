{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Character Creation Contract",
  "description": "Defines input/output contract for PC character creation including ability score generation, class selection, proficiency assignment, and equipment.",
  "version": "1.0",
  "input_schema": {
    "type": "object",
    "required": [
      "name",
      "class",
      "creation_method",
      "ability_input",
      "chosen_skills"
    ],
    "properties": {
      "name": {
        "type": "string",
        "description": "Character name"
      },
      "class": {
        "type": "string",
        "description": "Must be valid ID from all-classes.json registry"
      },
      "creation_method": {
        "type": "string",
        "enum": [
          "point_buy",
          "standard_array",
          "4d6_drop_lowest",
          "2d6_plus_6",
          "custom"
        ]
      },
      "ability_input": {
        "type": "object",
        "description": "Ability score distribution/assignment. Keys: STR, DEX, CON, INT, WIS, CHA",
        "properties": {
          "STR": {
            "type": "integer"
          },
          "DEX": {
            "type": "integer"
          },
          "CON": {
            "type": "integer"
          },
          "INT": {
            "type": "integer"
          },
          "WIS": {
            "type": "integer"
          },
          "CHA": {
            "type": "integer"
          }
        }
      },
      "chosen_skills": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Skill proficiencies chosen from class pool"
      },
      "equipment_choice": {
        "type": "string",
        "enum": [
          "option_a",
          "option_b",
          "option_c"
        ],
        "default": "option_a"
      },
      "race": {
        "type": "string",
        "description": "Must be valid ID from all-races.json registry"
      },
      "background": {
        "type": "string",
        "default": "soldier"
      },
      "admin_override": {
        "type": "boolean",
        "default": false
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": [
      "valid",
      "character",
      "errors"
    ],
    "properties": {
      "valid": {
        "type": "boolean"
      },
      "character": {
        "type": "object",
        "description": "Tier 4 PC entity",
        "properties": {
          "id": {
            "type": "string"
          },
          "entity_type": {
            "const": "pc"
          },
          "name": {
            "type": "string"
          },
          "character_class": {
            "type": "string"
          },
          "level": {
            "const": 1
          },
          "xp": {
            "const": 0
          },
          "ability_scores": {
            "type": "object"
          },
          "hp": {
            "type": "integer",
            "minimum": 1
          },
          "ac": {
            "type": "integer",
            "minimum": 8
          },
          "hit_dice_detail": {
            "type": "object"
          },
          "proficiency_bonus": {
            "const": 2
          },
          "proficiencies": {
            "type": "object"
          },
          "class_features": {
            "type": "array"
          },
          "inventory": {
            "type": "array"
          },
          "gold": {
            "type": "number"
          },
          "spell_slots": {
            "type": "object"
          },
          "personality": {
            "type": "object",
            "properties": {
              "alignment": { "type": "string" },
              "background": { "type": "string" },
              "traits": { "type": "array", "items": { "type": "string" }, "maxItems": 2 },
              "ideal": { "type": "string" },
              "bond": { "type": "string" },
              "flaw": { "type": "string" },
              "appearance": { "type": "string" },
              "backstory": { "type": "string" }
            }
          },
          "social": {
            "type": "object"
          },
          "creation_metadata": {
            "type": "object",
            "properties": {
              "creation_method": { "type": "string" },
              "created_date": { "type": "string" },
              "source_campaign": { "type": "string" }
            }
          },
          "campaign_history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "campaign_id": { "type": "string" },
                "joined_at_level": { "type": "integer" },
                "current_level": { "type": "integer" },
                "status": { "type": "string" }
              }
            }
          }
        }
      },
      "errors": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "validation_rules": [
    {
      "rule_id": "CHAR-001",
      "description": "All ability scores must be between 3 and 20 inclusive",
      "validation": "all(3 <= score <= 20 for score in ability_scores.values())"
    },
    {
      "rule_id": "CHAR-002",
      "description": "Point-buy total cost must not exceed 27 points",
      "validation": "sum(POINT_BUY_COSTS[score] for score in ability_scores.values()) <= 27",
      "applies_to": "point_buy"
    },
    {
      "rule_id": "CHAR-003",
      "description": "Standard array must use exactly [15, 14, 13, 12, 10, 8]",
      "validation": "sorted(ability_scores.values(), reverse=True) == [15, 14, 13, 12, 10, 8]",
      "applies_to": "standard_array"
    },
    {
      "rule_id": "CHAR-004",
      "description": "Chosen skill proficiencies must be from class pool and count <= class allowance",
      "validation": "all(skill in class_pool for skill in chosen_skills) and len(chosen_skills) <= class_skill_count"
    },
    {
      "rule_id": "CHAR-005",
      "description": "HP at level 1 = max(hit_die) + CON modifier, minimum 1",
      "validation": "hp == max(max_hit_die + con_modifier, 1)"
    },
    {
      "rule_id": "CHAR-006",
      "description": "Proficiency bonus at level 1 is 2",
      "validation": "proficiency_bonus == 2"
    },
    {
      "rule_id": "CHAR-007",
      "description": "Equipment weight must not exceed STR * 15",
      "validation": "total_weight <= ability_scores['STR'] * 15"
    },
    {
      "rule_id": "CHAR-008",
      "description": "Custom creation method requires admin_override flag",
      "validation": "admin_override == True when creation_method == 'custom'",
      "applies_to": "custom"
    }
  ],
