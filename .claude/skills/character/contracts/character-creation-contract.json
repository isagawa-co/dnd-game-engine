          "investigation"
        ],
        "equipment_choice": "option_a",
        "race": "elf",
        "background": "sage"
      },
      "execution": "generate_ability_scores(standard_array) -> assign_proficiencies(wizard) -> assign_equipment(wizard) -> create_character",
      "output": {
        "valid": true,
        "character": {
          "hp": 7,
          "ac": 12,
          "proficiency_bonus": 2,
          "spell_slots": {
            "1": 2
          }
        },
        "errors": []
      }
    }
