{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ability Check Contract",
  "description": "Ability check contract for D&D 5e: d20 + ability_mod + proficiency vs DC",
  "version": "1.0",
  "operation": "ability_check",
  "input_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Ability Check Input",
    "type": "object",
    "properties": {
      "ability_score": {
        "type": "integer",
        "minimum": 3,
        "maximum": 20,
        "description": "Ability score (STR, DEX, CON, INT, WIS, CHA)"
      },
      "proficiency": {
        "type": "integer",
        "minimum": 0,
        "maximum": 6,
        "description": "Proficiency bonus (0 = not proficient, 2-6 = proficient at levels 1-20)"
      },
      "dc": {
        "type": "integer",
        "minimum": 5,
        "maximum": 30,
        "description": "Difficulty class (5=trivial, 10=easy, 15=moderate, 20=hard, 25=very hard, 30=nearly impossible)"
      },
      "advantage": {
        "type": "boolean",
        "description": "Roll 2d20 take higher"
      },
      "disadvantage": {
        "type": "boolean",
        "description": "Roll 2d20 take lower"
      }
    },
    "required": ["ability_score", "proficiency", "dc", "advantage", "disadvantage"],
    "additionalProperties": false
  },
  "output_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Ability Check Output",
    "type": "object",
    "properties": {
      "roll": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "description": "The d20 result (after advantage/disadvantage applied)"
      },
      "ability_mod": {
        "type": "integer",
        "minimum": -4,
        "maximum": 5,
        "description": "Ability modifier: (ability_score - 10) / 2 rounded down"
      },
      "proficiency_bonus": {
        "type": "integer",
        "minimum": 0,
        "maximum": 6,
        "description": "Proficiency bonus applied (0 if not proficient)"
      },
      "total": {
        "type": "integer",
        "minimum": -3,
        "maximum": 31,
        "description": "roll + ability_mod + proficiency_bonus"
      },
      "dc": {
        "type": "integer",
        "minimum": 5,
        "maximum": 30
      },
      "success": {
        "type": "boolean",
        "description": "true if total >= dc"
      }
    },
    "required": ["roll", "ability_mod", "proficiency_bonus", "total", "dc", "success"],
    "additionalProperties": false
  },
  "validation_rules": [
    {
      "rule_id": "CHECK-001",
      "description": "ability_score must be 3-20",
      "validation": "3 <= ability_score <= 20",
      "error_message": "Ability score out of range"
    },
    {
      "rule_id": "CHECK-002",
      "description": "proficiency must be 0 or 2-6 per level",
      "validation": "proficiency in [0, 2, 3, 4, 5, 6]",
      "error_message": "Proficiency bonus invalid"
    },
    {
      "rule_id": "CHECK-003",
      "description": "dc must be 5-30",
      "validation": "5 <= dc <= 30",
      "error_message": "DC out of range"
    },
    {
      "rule_id": "CHECK-004",
      "description": "advantage and disadvantage cannot both be true",
      "validation": "NOT (advantage AND disadvantage)",
      "error_message": "Cannot have both advantage and disadvantage"
    }
  ],
  "formulas": {
    "ability_modifier": "(ability_score - 10) / 2 rounded down (integer division)",
    "total": "roll + ability_mod + proficiency_bonus",
    "success": "total >= dc"
  },
  "examples": [
    {
      "name": "Moderate Athletics Check (STR 16, not proficient)",
      "input": { "ability_score": 16, "proficiency": 0, "dc": 15, "advantage": false, "disadvantage": false },
      "execution": "Roll d20 -> 12, ability_mod = (16-10)/2 = 3, prof = 0, total = 12+3+0 = 15, success = (15>=15) = true",
      "output": { "roll": 12, "ability_mod": 3, "proficiency_bonus": 0, "total": 15, "dc": 15, "success": true }
    },
    {
      "name": "Hard Arcana Check (INT 12, proficient +3)",
      "input": { "ability_score": 12, "proficiency": 3, "dc": 20, "advantage": false, "disadvantage": false },
      "execution": "Roll d20 -> 10, ability_mod = (12-10)/2 = 1, prof = 3, total = 10+1+3 = 14, success = (14>=20) = false",
      "output": { "roll": 10, "ability_mod": 1, "proficiency_bonus": 3, "total": 14, "dc": 20, "success": false }
    },
    {
      "name": "With Advantage (DEX 14, proficient +2)",
      "input": { "ability_score": 14, "proficiency": 2, "dc": 12, "advantage": true, "disadvantage": false },
      "execution": "Roll 2d20 -> [8, 16], select higher = 16, ability_mod = (14-10)/2 = 2, prof = 2, total = 16+2+2 = 20, success = (20>=12) = true",
      "output": { "roll": 16, "ability_mod": 2, "proficiency_bonus": 2, "total": 20, "dc": 12, "success": true }
    }
  ],
  "dependencies": {
    "uses": ["dice_roll"],
    "used_by": ["scene_loop"]
  }
}
