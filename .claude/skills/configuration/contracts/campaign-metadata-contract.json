{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Campaign Metadata",
  "description": "Campaign identity, versioning, content pack references, level progression, and session planning.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100,
      "description": "Campaign title (e.g., Lost Mine of Phandelver)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic versioning (major.minor.patch) for campaign configuration"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief description of campaign premise and goals"
    },
    "content_packs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Required content pack IDs (must exist in content catalog)"
    },
    "level_range": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1, "maximum": 20 },
      "minItems": 2,
      "maxItems": 2,
      "description": "Starting level and ending level (e.g., [1, 5])"
    },
    "session_count_estimate": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Estimated number of sessions to complete campaign"
    },
    "session_length_hours": {
      "type": "number",
      "minimum": 1,
      "maximum": 12,
      "default": 3,
      "description": "Typical session duration in hours"
    },
    "starting_gold": {
      "type": "integer",
      "minimum": 0,
      "description": "Gold each character begins with"
    },
    "long_rest_rule_hours": {
      "type": "integer",
      "minimum": 1,
      "maximum": 24,
      "default": 8,
      "description": "Hours required for long rest"
    },
    "short_rest_rule_minutes": {
      "type": "integer",
      "minimum": 10,
      "maximum": 120,
      "default": 60,
      "description": "Minutes required for short rest"
    },
    "campaign_author": {
      "type": "string",
      "description": "Name of campaign creator/DM"
    },
    "created_date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of campaign creation"
    }
  },
  "required": [
    "name",
    "version",
    "content_packs",
    "level_range",
    "session_count_estimate",
    "starting_gold"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "name": "Lost Mine of Phandelver",
      "config": {
        "name": "Lost Mine of Phandelver",
        "version": "1.0.0",
        "description": "Official D&D 5e Starter Set adventure. Party investigates the disappearance of dwarf Gundren Rockseeker near Phandalin.",
        "content_packs": ["lost-mine-phandelver"],
        "level_range": [1, 5],
        "session_count_estimate": 15,
        "session_length_hours": 3.5,
        "starting_gold": 50,
        "long_rest_rule_hours": 8,
        "short_rest_rule_minutes": 60,
        "campaign_author": "Wizards of the Coast",
        "created_date": "2026-01-15T10:00:00Z"
      }
    },
    {
      "name": "Curse of Strahd Extended",
      "config": {
        "name": "The Curse of Strahd - Extended",
        "version": "2.1.0",
        "description": "Extended Curse of Strahd with additional side quests, expanded Barovia, and harder final boss.",
        "content_packs": ["curse-of-strahd", "curse-of-strahd-extended"],
        "level_range": [3, 10],
        "session_count_estimate": 40,
        "session_length_hours": 4,
        "starting_gold": 200,
        "long_rest_rule_hours": 8,
        "short_rest_rule_minutes": 60,
        "campaign_author": "Custom DM",
        "created_date": "2026-05-20T14:30:00Z"
      }
    },
    {
      "name": "One-Shot Dungeon Crawl",
      "config": {
        "name": "Tomb of the Forgotten King",
        "version": "1.0.0",
        "description": "Single-session dungeon crawl for experienced players.",
        "content_packs": ["core-5e"],
        "level_range": [5, 5],
        "session_count_estimate": 1,
        "session_length_hours": 4,
        "starting_gold": 500,
        "long_rest_rule_hours": 8,
        "short_rest_rule_minutes": 30
      }
    }
  ],
  "validation_rules": [
    {
      "rule_id": "META-001",
      "description": "Starting level must be less than or equal to ending level",
      "validation": "level_range[0] <= level_range[1]",
      "error_message": "Starting level must be less than or equal to ending level"
    },
    {
      "rule_id": "META-002",
      "description": "All content_packs must exist in content catalog",
      "validation": "for pack_id in content_packs: assert pack_id in catalog.packs",
      "error_message": "Unknown content pack referenced"
    },
    {
      "rule_id": "META-003",
      "description": "Version must be semantic versioning format",
      "validation": "regex: ^\\d+\\.\\d+\\.\\d+$",
      "error_message": "Version must be X.Y.Z format"
    },
    {
      "rule_id": "META-004",
      "description": "Session count estimate must be at least 1",
      "validation": "session_count_estimate >= 1",
      "error_message": "Estimate must be at least 1 session"
    }
  ]
}
